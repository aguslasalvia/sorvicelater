{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "notifications/templates/**/*.hbs", "outDir": "dist" },
      { "include": "notifications/assets/**/*", "outDir": "dist" }
    ]
  }
}
