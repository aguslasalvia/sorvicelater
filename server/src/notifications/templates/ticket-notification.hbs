<!DOCTYPE html>
<html lang="es" xmlns="http://www.w3.org/1999/xhtml">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="color-scheme" content="light" />
    <title>{{subject}}</title>
  </head>
  <body style="margin:0; padding:0; width:100%; background-color:#fbece2; -webkit-font-smoothing:antialiased;">
    <!-- Preheader: texto oculto en la vista previa del inbox -->
    <div style="display:none; max-height:0; overflow:hidden; opacity:0; mso-hide:all;">
      {{preheader}}
    </div>

    <!-- Fondo durazno cálido (como el dashboard) -->
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
           style="background-color:#fbece2; background-image:linear-gradient(160deg,#fde4d4,#fbf6f2 55%,#f6f7f9);">
      <tr>
        <td align="center" style="padding:44px 16px;">

          <!-- Marca -->
          <table role="presentation" width="480" cellpadding="0" cellspacing="0" style="width:600px; max-width:600px;">
            <tr>
              <td style="padding:0 4px 14px 4px; font-family:Arial,sans-serif; font-size:14px; font-weight:bold; color:#16181d;">
                {{#if brandName}}{{brandName}}{{else}}SorvisLater{{/if}}
              </td>
            </tr>
          </table>

          <!-- Card de incidente -->
          <table role="presentation" width="600" cellpadding="0" cellspacing="0"
                 style="width:600px; max-width:600px; background-color:#ffffff; border:1px solid #eceef1; border-radius:18px; box-shadow:0 8px 24px rgba(214,72,28,0.08);">
            <tr>
              <td style="padding:34px 36px;">

                <!-- Fila superior: código + estado -->
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td style="vertical-align:middle;">
                      <span style="display:inline-block; font-family:Arial,sans-serif; font-size:12px; font-weight:bold; color:#d6481c; background-color:#fce4d8; border:1px solid #d6481c; padding:4px 11px; border-radius:8px;">
                        {{ticketCode}}
                      </span>
                    </td>
                    {{#if statusLabel}}
                    <td align="right" style="vertical-align:middle;">
                      <span style="display:inline-block; font-family:Arial,sans-serif; font-size:12px; font-weight:bold; color:{{#if statusTextColor}}{{statusTextColor}}{{else}}#d6481c{{/if}}; background-color:{{#if statusColor}}{{statusColor}}{{else}}#fce4d8{{/if}}; border:1px solid {{#if statusTextColor}}{{statusTextColor}}{{else}}#d6481c{{/if}}; padding:4px 11px; border-radius:8px;">
                        {{statusLabel}}
                      </span>
                    </td>
                    {{/if}}
                  </tr>
                </table>

                <!-- Título -->
                <h1 style="margin:22px 0 24px 0; font-family:Arial,sans-serif; font-size:23px; line-height:31px; font-weight:bold; color:#16181d;">
                  {{title}}
                </h1>

                <!-- For -->
                {{#if requestedFor}}
                <p style="margin:0 0 10px 0; font-family:Arial,sans-serif; font-size:14px; color:#16181d;">
                  <span style="color:#9aa0a8;">For</span>&nbsp;&nbsp;{{requestedFor}}
                </p>
                {{/if}}

                <!-- Assignee + botón flecha -->
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td style="vertical-align:middle; font-family:Arial,sans-serif; font-size:14px; color:#16181d;">
                      {{#if assignee}}<span style="color:#9aa0a8;">Assignee</span>&nbsp;&nbsp;{{assignee}}{{/if}}
                    </td>
                    {{#if actionUrl}}
                    <td align="right" style="vertical-align:middle;">
                      <a href="{{actionUrl}}" target="_blank" rel="noopener noreferrer"
                         style="display:inline-block; width:38px; height:38px; line-height:38px; text-align:center; font-family:Arial,sans-serif; font-size:17px; font-weight:bold; color:#d6481c; background-color:#fce4d8; border:1px solid #d6481c; border-radius:9px; text-decoration:none;">
                        &rarr;
                      </a>
                    </td>
                    {{/if}}
                  </tr>
                </table>

              </td>
            </tr>
          </table>
          <!-- /Card -->

          <!-- Footer -->
          <table role="presentation" width="480" cellpadding="0" cellspacing="0" style="width:600px; max-width:600px;">
            <tr>
              <td style="padding:18px 4px 0 4px; font-family:Arial,sans-serif; font-size:12px; line-height:18px; color:#a58c81;">
                {{#if footerNote}}{{footerNote}}{{else}}Mensaje automático, por favor no respondas a este correo.{{/if}}
              </td>
            </tr>
          </table>

        </td>
      </tr>
    </table>
  </body>
</html>
