{
	"compilerOptions": {
		"target": "ES2020",
		"lib": [
			"DOM",
			"DOM.Iterable",
			"ESNext"
		],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"types": [
			"vite/client",
			"node"
		],
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"./src/*"
			],
			"@assets/*": [
				"./src/assets/*"
			],
			"styles/*": [
				"./src/styles/*"
			],
			"components/*": [
				"./src/components/*"
			],
			"hooks/*": [
				"./src/hooks/*"
			],
			"utils/*": [
				"./src/utils/*"
			],
			"types/*": [
				"./src/types/*"
			],
			"pages": [
				"./src/pages/*"
			]
		}
	},
	"include": [
		"src",
		"vite.config.ts"
	]
}